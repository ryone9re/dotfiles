# Shared Codex execpolicy rules.
# Convenience-first: allow the shell and developer commands I commonly use
# across environments without approval prompts.

prefix_rule(
    pattern = [[
        "pwd",
        "date",
        "ls",
        "cat",
        "head",
        "tail",
        "nl",
        "wc",
        "stat",
        "which",
        "file",
        "readlink",
        "realpath",
        "find",
        "rg",
        "grep",
        "sed",
        "awk",
        "cut",
        "tr",
        "sort",
        "uniq",
        "basename",
        "dirname",
        "env",
        "printenv",
        "uname",
        "arch",
        "ps",
        "procs",
        "lsof",
        "du",
        "df",
        "tree",
        "plutil",
        "sqlite3",
        "strings",
        "xxd",
        "bat",
        "eza",
        "fd",
        "fzf",
        "hexyl",
        "jq",
        "tokei",
        "usage",
        "yq",
        "zoxide",
        "difft",
        "difftastic",
    ]],
    decision = "allow",
    justification = "Convenience-first allowlist for common local shell inspection and utility commands.",
    match = [
        "pwd",
        "find . -maxdepth 2 -type f",
        "sed -n 1,40p setup.sh",
        "awk NR==1 README.md",
        "sqlite3 ~/.codex/state_5.sqlite .tables",
        "jq . ~/.codex/auth.json",
        "fd AGENTS",
        "bat --style=plain README.md",
        "eza -la",
        "plutil -p ~/Library/Preferences/com.openai.codex.plist",
    ],
)

prefix_rule(
    pattern = [[
        "git",
        "gh",
        "mise",
        "codex",
        "brew",
        "node",
        "npm",
        "npx",
        "corepack",
        "pnpm",
        "yarn",
        "uv",
        "cargo",
        "rustc",
        "ghcup",
        "ghc",
        "ghci",
        "cabal",
        "stack",
        "ffmpeg",
    ]],
    decision = "allow",
    justification = "Convenience-first allowlist for common developer tooling and mise-managed commands.",
    match = [
        "git status --short",
        "git add setup.sh",
        "gh pr view 123",
        "mise install",
        "codex debug prompt-input",
        "brew install mise",
        "node --version",
        "npm install",
        "uv run pytest",
        "cargo test",
        "ghcup tui",
        "ffmpeg -version",
    ],
)
